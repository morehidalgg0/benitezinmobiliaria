# Database configuration (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# JWT configuration for Admin panel
JWT_SECRET="your-jwt-secret-key"

# Application base URL
NEXT_PUBLIC_APP_URL="http://localhost:3005"

# Sincronización de APIs - Modo Simulación
# Seteado en true para probar localmente sin credenciales reales
API_SIMULATION_MODE="true"

# Argenprop REST API credentials
ARGENPROP_API_KEY=""

# Mercado Libre API credentials
# Category MLA1459 (Propiedades - Argentina)
MELI_CLIENT_ID=""
MELI_CLIENT_SECRET=""
