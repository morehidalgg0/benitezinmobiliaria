datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String // hashed password
}

model Property {
  id           Int              @id @default(autoincrement())
  title        String
  description  String
  price        Float
  currency     String           @default("USD") // "ARS" or "USD"
  type         String           // "CASA", "DEPARTAMENTO", "LOTE", "PH", "LOCAL"
  operation    String           // "VENTA", "ALQUILER", "ALQUILER_TEMPORARIO"
  totalArea    Float            // In square meters
  coveredArea  Float            // In square meters
  rooms        Int
  bedrooms     Int
  bathrooms    Int
  garage       Boolean          @default(false)
  address      String
  neighborhood String           // Barrio / Zona
  images       String           // JSON stringified array of URLs/Base64 strings
  featured     Boolean          @default(false)
  active       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  syncState    SyncState?
  messages     ContactMessage[]
}

model Development {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  status      String   // "CONSTRUCTION" or "FINISHED"
  location    String
  images      String   // JSON stringified array of URLs/Base64 strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SyncState {
  id              Int       @id @default(autoincrement())
  propertyId      Int       @unique
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  argenpropId     String?
  argenpropStatus String    @default("NOT_PUBLISHED") // "NOT_PUBLISHED", "PENDING", "ACTIVE", "ERROR"
  argenpropError  String?
  meliId          String?
  meliStatus      String    @default("NOT_PUBLISHED") // "NOT_PUBLISHED", "PENDING", "ACTIVE", "PAUSED", "ERROR"
  meliError       String?
  lastSynced      DateTime?
}

model ContactMessage {
  id         Int       @id @default(autoincrement())
  name       String
  email      String
  phone      String
  message    String
  propertyId Int?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
}

model MeliCredentials {
  id           Int      @id @default(1) // Always id = 1 (singleton)
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
}
